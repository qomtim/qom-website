---
import { site, nav } from "../data/content.js";
---

<footer>
  <div class="container">
    <div class="footer-grid">
      <div class="footer-col">
        <a class="logo" href="/">{site.shortName}<span>.</span></a>
        <p style="color: var(--muted); max-width: 32ch; margin-top: 14px;">
          Quit Ordinary Marketing – {site.claim}
        </p>
      </div>
      <div class="footer-col">
        <h5>Navigation</h5>
        {nav.filter((n) => n.href !== "/").map((n) => <a href={n.href}>{n.label}</a>)}
      </div>
      <div class="footer-col">
        <h5>Kontakt</h5>
        <a href={`mailto:${site.email}`}>{site.email}</a>
        <a href={`tel:${site.phoneLink}`}>{site.phone}</a>
      </div>
      <div class="footer-col">
        <h5>Rechtliches</h5>
        <a href="/impressum">Impressum</a>
        <a href="/datenschutz">Datenschutzerklärung</a>
      </div>
    </div>
    <div class="footer-bottom">
      <span>© {site.year} {site.name}, {site.city}</span>
      <span>Gehostet in der Schweiz 🇨🇭</span>
    </div>
  </div>
</footer>
