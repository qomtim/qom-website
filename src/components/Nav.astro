---
import { site, nav } from "../data/content.js";
const path = Astro.url.pathname.replace(/\/$/, "") || "/";
---

<nav class="nav">
  <div class="nav-inner">
    <a class="logo" href="/" aria-label={site.name}>
      <img class="logo-img" src={site.logoUrl} alt={site.name} data-sb-img="logo_url" />
    </a>
    <ul class="nav-links">
      {
        nav.map((item) => (
          <li>
            <a href={item.href} class={path === item.href.replace(/\/$/, "") ? "active" : ""}>
              {item.label}
            </a>
          </li>
        ))
      }
      <li>
        <a class="btn btn-primary" href={site.bookingUrl} target="_blank" rel="noopener">
          {site.bookingLabel}
        </a>
      </li>
    </ul>
    <button class="burger" aria-label="Menü">☰</button>
  </div>
</nav>
