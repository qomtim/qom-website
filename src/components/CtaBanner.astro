---
import { site } from "../data/site.js";

interface Props {
  title: string;
  text: string;
}

const { title, text } = Astro.props;
---

<section class="section-tight">
  <div class="container">
    <div class="cta-banner reveal">
      <div>
        <h2>{title}</h2>
        <p style="margin-top: 14px;">{text}</p>
      </div>
      <a class="btn btn-dark btn-lg" href={site.bookingUrl} target="_blank" rel="noopener">
        {site.bookingLabel}
      </a>
    </div>
  </div>
</section>
