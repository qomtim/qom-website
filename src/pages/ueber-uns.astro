---
import Layout from "../layouts/Layout.astro";
import CtaBanner from "../components/CtaBanner.astro";
import { team, ueberUns } from "../data/content.js";
---

<Layout
  title="Über uns | QOM – Quit Ordinary Marketing"
  description="Von der Schulbank zum Start-up: Wir sind QOM, ein junges Team aus Bösingen. Lernen Sie uns kennen."
>
  <header class="page-hero">
    <div class="container">
      <p class="label" data-sbp="label">{ueberUns.label}</p>
      <h1 class="display">
        <span data-sbp="titel_1">{ueberUns.titel1}</span>
        <span class="accent" data-sbp="titel_accent">{ueberUns.titelAccent}</span>.
      </h1>
    </div>
  </header>

  <section class="section">
    <div class="container two-col">
      <div class="prose reveal">
        <p data-sbp="absatz_1">{ueberUns.absatz1}</p>
        <p data-sbp="absatz_2">{ueberUns.absatz2}</p>
      </div>
      <div class="card-img reveal" style="aspect-ratio: 4 / 3; border-radius: var(--radius); overflow: hidden;">
        <img src={ueberUns.bild} alt="Das QOM-Team" data-sbp-img="bild" />
      </div>
    </div>
  </section>

  <section class="section" style="background: var(--surface); border-block: 1px solid var(--line);">
    <div class="container">
      <div class="section-head reveal">
        <div>
          <p class="label" data-sbp="team_label">{ueberUns.teamLabel}</p>
          <h2 class="h2" data-sbp="team_titel">{ueberUns.teamTitel}</h2>
        </div>
      </div>
      <div class="team-grid">
        {
          team.map((m) => (
            <div class="member reveal" data-sb-uid={m.uid}>
              <div class="photo">
                <img src={m.image} alt={m.name} data-sb-f-img="image" />
              </div>
              <h4 data-sb-f="name">{m.name}</h4>
              <p data-sb-f="role">{m.role}</p>
              {m.linkedin && (
                <a href={m.linkedin} target="_blank" rel="noopener">
                  LinkedIn →
                </a>
              )}
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <CtaBanner
    title="Lernen wir uns kennen."
    text="Unverbindliches Erstgespräch mit Tim – Wunschtermin direkt online wählen."
  />
</Layout>
