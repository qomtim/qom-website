---
import Layout from "../layouts/Layout.astro";
import CtaBanner from "../components/CtaBanner.astro";
import { site, services, cases, regio, quotes, stats, hero, about } from "../data/content.js";
---

<Layout
  title="QOM – Quit Ordinary Marketing | Digitales Wachstum aus Bösingen"
  description="Webseiten, Online-Shops & Social-Media-Kampagnen aus Bösingen. Alles unter einem Dach. Ihr persönliches Marketing-Team für die Region."
>
  <!-- Hero -->
  <header class="hero">
    <div class="hero-blob" aria-hidden="true"></div>
    <div class="container">
      <p class="label" data-sb="hero_label">{hero.label}</p>
      <h1 class="display">
        <span class="line-reveal"><span data-sb="hero_title_1">{hero.title1}</span></span>
        <span class="line-reveal"><span><span class="accent" data-sb="hero_title_accent">{hero.titleAccent}</span></span></span>
        <span class="line-reveal"><span data-sb="hero_title_2">{hero.title2}</span></span>
      </h1>
      <div class="hero-row">
        <p class="lead" data-sb="hero_lead">{hero.lead}</p>
        <div class="hero-cta">
          <a class="btn btn-primary btn-lg" href={site.bookingUrl} target="_blank" rel="noopener">
            Erstgespräch mit Tim buchen
          </a>
          <a class="btn btn-ghost btn-lg" href="/projekte">Unsere Arbeiten</a>
        </div>
      </div>
      <div class="hero-img img-reveal">
        <img src={hero.image} alt="Das QOM-Team bei der Arbeit" loading="eager" data-sb-img="hero_image" />
      </div>
    </div>
    <div class="marquee" aria-hidden="true">
      <div class="marquee-track">
        {[1, 2, 3, 4].map(() => (
          <>Webdesign <b>·</b> Online-Shops <b>·</b> Social Media Kampagnen <b>·</b> Regional verankert <b>·</b> Schweizer Hosting <b>·</b>{" "}</>
        ))}
      </div>
    </div>
  </header>

  <!-- Zahlen -->
  <section class="container">
    <div class="stats">
      {
        stats.map((s) => (
          <div class="stat reveal" data-sb-uid={s.uid}>
            <span class="num" data-count={s.value} data-suffix={s.suffix}>
              0
            </span>
            <p data-sb-f="label">{s.label}</p>
          </div>
        ))
      }
    </div>
  </section>

  <!-- Über uns Teaser -->
  <section class="section">
    <div class="container two-col">
      <div class="reveal">
        <p class="label">Über uns</p>
        <h2 class="h2" data-sb="about_title">{about.title}</h2>
        <div class="prose" style="margin-top: 24px;">
          <p data-sb="about_text">{about.text}</p>
        </div>
        <div style="margin-top: 30px;">
          <a class="btn btn-ghost" href="/ueber-uns">Mehr erfahren</a>
        </div>
      </div>
      <div class="card-img reveal" style="aspect-ratio: 1 / 1; border-radius: var(--radius); overflow: hidden;">
        <img src={about.image} alt="QOM – Quit Ordinary Marketing" data-sb-img="about_image" />
      </div>
    </div>
  </section>

  <!-- Dienstleistungen -->
  <section class="section" id="dienstleistungen" style="background: var(--surface); border-block: 1px solid var(--line);">
    <div class="container">
      <div class="section-head reveal">
        <div>
          <p class="label">Dienstleistungen</p>
          <h2 class="h2">Unsere Lösungen für Ihr Wachstum</h2>
        </div>
      </div>
      <ul class="service-rows reveal">
        {
          services.map((s) => (
            <li data-sb-uid={s.uid}>
              <a class="service-row" href={`/${s.slug}`} data-img={s.image}>
                <span class="num" data-sb-f="num">{s.num}</span>
                <h3 data-sb-f="title">{s.title}</h3>
                <p data-sb-f="teaser">{s.teaser}</p>
                <span class="arrow">→</span>
                <div class="mobile-img">
                  <img src={s.image} alt={s.title} loading="lazy" />
                </div>
              </a>
            </li>
          ))
        }
      </ul>
    </div>
  </section>

  <!-- Case Studies -->
  <section class="section">
    <div class="container">
      <div class="section-head reveal">
        <div>
          <p class="label">Case Studies</p>
          <h2 class="h2">Gemeinsame Erfolge</h2>
        </div>
        <a class="btn btn-ghost" href="/projekte">Alle Case Studies ansehen</a>
      </div>
      <div class="cards-2">
        {
          cases.map((c) => (
            <a class="card reveal" href={c.url} target="_blank" rel="noopener" data-sb-uid={c.uid}>
              <div class="card-img">
                <img src={c.image} alt={`Webseite ${c.title}`} loading="lazy" data-sb-f-img="image" />
              </div>
              <span class="tag" data-sb-f="tag">{c.tag}</span>
              <h3 class="h3" data-sb-f="title">{c.title}</h3>
              <p data-sb-f="text">{c.text}</p>
              <span class="card-link" data-sb-f="link_label">{c.linkLabel}</span>
            </a>
          ))
        }
      </div>
    </div>
  </section>

  <!-- Regional verankert -->
  <section class="regio-section" style="background: var(--surface); border-block: 1px solid var(--line);">
    <div class="container">
      <div class="reveal">
        <p class="label">Regional verankert</p>
        <h2 class="h2">Nicht nur digital unterwegs.</h2>
        <p class="lead" style="margin-top: 20px;">
          Wir sind auch persönlich in der Region präsent – vernetzt, engagiert und nahe am lokalen
          Wirtschaftsraum.
        </p>
      </div>
      <div class="regio-grid">
        {
          regio.map((r) => (
            <div class="regio-card reveal" data-sb-uid={r.uid}>
              <div class="regio-img">
                <img src={r.image} alt={r.title} loading="lazy" data-sb-f-img="image" />
              </div>
              <div class="regio-body">
                <h4 data-sb-f="title">{r.title}</h4>
                <p data-sb-f="text">{r.text}</p>
              </div>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- Referenzen -->
  <section class="section">
    <div class="container">
      <div class="section-head reveal">
        <div>
          <p class="label">Referenzen</p>
          <h2 class="h2">Das sagen unsere Kunden</h2>
        </div>
      </div>
      <div class="cards-2">
        {
          quotes.map((q) => (
            <div class="quote-card reveal" data-sb-uid={q.uid}>
              <span class="stars">★★★★★</span>
              <p data-sb-f="text">{q.text}</p>
              <span class="who" data-sb-f="who">{q.who}</span>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <CtaBanner
    title="Bereit für digitales Wachstum?"
    text="Sichern Sie sich jetzt Ihr unverbindliches Erstgespräch mit Tim und wählen Sie direkt Ihren Wunschtermin."
  />
</Layout>
