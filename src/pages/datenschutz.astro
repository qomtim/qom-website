---
import Layout from "../layouts/Layout.astro";
import { datenschutz } from "../data/content.js";
---

<Layout title="Datenschutzerklärung | QOM – Quit Ordinary Marketing" noindex={true}>
  <section class="legal">
    <div class="container">
      <h1 class="h2" style="margin-bottom: 30px;">Datenschutzerklärung</h1>
      <div class="prose">
        <h2>1. Verantwortliche Stelle</h2>
        <p class="pre-line" data-sbp="verantwortlich">{datenschutz.verantwortlich}</p>

        <h2>2. Erhebung und Bearbeitung von Personendaten</h2>
        <p data-sbp="erhebung">{datenschutz.erhebung}</p>

        <h2>3. Terminbuchung</h2>
        <p data-sbp="terminbuchung">{datenschutz.terminbuchung}</p>

        <h2>4. Hosting</h2>
        <p data-sbp="hosting">{datenschutz.hosting}</p>

        <h2>5. Weitergabe an Dritte</h2>
        <p data-sbp="weitergabe">{datenschutz.weitergabe}</p>

        <h2>6. Ihre Rechte</h2>
        <p data-sbp="rechte">{datenschutz.rechte}</p>

        <h2>7. Änderungen</h2>
        <p data-sbp="aenderungen">{datenschutz.aenderungen}</p>

        <p><em data-sbp="stand">{datenschutz.stand}</em></p>
      </div>
    </div>
  </section>
</Layout>
